@model List<CourseTrashItemViewModel>

@{
    ViewData["Title"] = "Thùng Rác Khóa Học";
    var currentTheme = ViewData["Theme"]?.ToString() ?? "light";
}

<div class="container py-4 course-page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Thùng Rác — Khóa Học Đã Ngưng Tuyển Sinh</h2>
            <p class="page-description">Các khóa học đã xóa mềm (IsDeleted = true). Có thể khôi phục về danh sách hoạt động.</p>
        </div>

        <a asp-controller="Courses" asp-action="Index" asp-route-theme="@currentTheme"
           class="btn app-btn app-btn-ghost fw-bold px-4">
            <i class="bi bi-arrow-left me-2"></i>Danh sách hoạt động
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state text-center p-5 rounded-4">
            <div class="display-6 fw-bold mb-2">Thùng rác trống</div>
            <p class="text-muted mb-0">Chưa có khóa học nào bị xóa mềm.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm rounded-4 p-0 overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã</th>
                        <th>Tên khóa học</th>
                        <th>Chuyên ngành</th>
                        <th>Thời điểm xóa</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@item.Code</td>
                            <td>@item.Name</td>
                            <td>@item.Category</td>
                            <td>@item.DeletedAtText</td>
                            <td class="text-end">
                                <form asp-controller="Courses" asp-action="Restore"
                                      asp-route-theme="@currentTheme" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-success btn-sm fw-bold">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>Khôi phục
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
